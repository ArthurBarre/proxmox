# Kubeconfig récupéré automatiquement par Ansible lors du provisionnement K3s
# Le fichier réel (kubeconfig.yaml) est dans le .gitignore
#
# Pour l'utiliser depuis ton laptop (via Tailscale) :
#   export KUBECONFIG=~/dev/perso/proxmox/k3s/kubeconfig.yaml
#   kubectl get nodes
#
# IMPORTANT : remplacer 127.0.0.1 par l'IP Tailscale du k3s-master (100.78.207.119)
# dans le fichier kubeconfig récupéré

apiVersion: v1
kind: Config
clusters:
  - cluster:
      server: https://100.78.207.119:6443
      # certificate-authority-data: <auto-filled>
    name: default
contexts:
  - context:
      cluster: default
      user: default
    name: default
current-context: default
users:
  - name: default
    user:
      # client-certificate-data: <auto-filled>
      # client-key-data: <auto-filled>
