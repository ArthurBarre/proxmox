# docker-compose.yml — rebours.studio
# Déployé sur VM docker (10.10.10.4)
# Trafic routé via Traefik (10.10.10.2)
version: "3.8"

services:
  nginx:
    image: nginx:alpine
    container_name: rebours-nginx
    restart: unless-stopped
    ports:
      - "8080:80"
    volumes:
      - ./dist:/usr/share/nginx/html:ro
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro

  api:
    image: node:20-alpine
    container_name: rebours-api
    restart: unless-stopped
    working_dir: /app
    ports:
      - "3000:3000"
    volumes:
      - ./server:/app
    command: node server.mjs
    env_file:
      - .env
    environment:
      - NODE_ENV=production
      - PORT=3000
