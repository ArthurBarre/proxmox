server:
  http_listen_port: 9080

positions:
  filename: /tmp/positions.yaml

clients:
  - url: {{ promtail_loki_url }}/loki/api/v1/push

scrape_configs:
  - job_name: syslog
    static_configs:
      - targets: [localhost]
        labels:
          host: "{{ inventory_hostname }}"
          job: syslog
          __path__: /var/log/syslog

  - job_name: auth
    static_configs:
      - targets: [localhost]
        labels:
          host: "{{ inventory_hostname }}"
          job: auth
          __path__: /var/log/auth.log

  - job_name: kernel
    static_configs:
      - targets: [localhost]
        labels:
          host: "{{ inventory_hostname }}"
          job: kernel
          __path__: /var/log/kern.log
