# Dynamic config — headlamp.arthurbarre.fr → Headlamp (Tailscale only)
http:
  routers:
    headlamp:
      rule: "Host(`headlamp.arthurbarre.fr`)"
      entryPoints:
        - websecure
      service: headlamp
      middlewares:
        - tailscale-only
        - security-headers
      tls:
        certResolver: letsencrypt

  services:
    headlamp:
      loadBalancer:
        servers:
          - url: "http://10.10.10.5:30090"
