# Dynamic config — freedge.app → Freedge (K3s NodePort)
http:
  routers:
    freedge:
      rule: "Host(`freedge.app`)"
      entryPoints:
        - websecure
      service: freedge
      middlewares:
        # `allow-indexing` AVANT `security-headers` : Traefik applique les
        # responseModifiers dans l'ordre inverse, donc le 1er listé écrit
        # X-Robots-Tag en dernier → c'est lui qui gagne (cf. middlewares.yml.j2).
        - allow-indexing
        - security-headers
        - rate-limit
      tls:
        certResolver: letsencrypt

    freedge-www:
      rule: "Host(`www.freedge.app`)"
      entryPoints:
        - websecure
      service: freedge
      middlewares:
        # `allow-indexing` AVANT `security-headers` : Traefik applique les
        # responseModifiers dans l'ordre inverse, donc le 1er listé écrit
        # X-Robots-Tag en dernier → c'est lui qui gagne (cf. middlewares.yml.j2).
        - allow-indexing
        - security-headers
        - rate-limit
      tls:
        certResolver: letsencrypt

  services:
    freedge:
      loadBalancer:
        servers:
          - url: "http://10.10.10.5:30082"
